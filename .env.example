# =============================================================================
# Pokémon Stock Radar — environment
# Copy to .env.local. Defaults run the app in DEMO mode with zero paid keys.
# @psr/config validates these at boot and fails fast with a readable message.
# =============================================================================

# Master switch: "demo" (fixtures, no secrets required) or "live".
DATA_MODE=demo
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (required only when DATA_MODE=live) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# --- Stripe (optional; mock billing when unset) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_COLLECTOR_PRO_MONTHLY_PRICE_ID=
STRIPE_COLLECTOR_PRO_ANNUAL_PRICE_ID=

# --- Upstash Redis (cache / locks / rate limiting; optional) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Trigger.dev (background jobs; optional) ---
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# --- Resend (transactional email; optional) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Sentry (monitoring; optional) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- PostHog (analytics; optional) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Vision service (grade-potential; optional) ---
VISION_SERVICE_URL=
VISION_SERVICE_API_KEY=

# --- Provider selectors (each accepts "demo") ---
CATALOG_PROVIDER=demo
RECOGNITION_PROVIDER=demo
RAW_PRICING_PROVIDER=demo
GRADED_PRICING_PROVIDER=demo
POPULATION_PROVIDER=demo
CERTIFICATION_PROVIDER=demo
ACTIVE_LISTINGS_PROVIDER=demo

# --- Provider credentials (only when the matching provider is selected) ---
SCRYDEX_API_KEY=
JUSTTCG_API_KEY=
POKEMON_TCG_API_KEY=
PRICECHARTING_API_KEY=
PSA_API_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
