# =============================================================================
# Pokémon Stock Radar — environment
# Copy to .env.local. Defaults run the app in DEMO mode with zero paid keys.
# @psr/config validates these at boot and fails fast with a readable message.
# =============================================================================

# Master switch: "demo" (fixtures, no secrets required) or "live".
DATA_MODE=demo
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ WANT REAL CARDS + REAL RAW PRICES, FREE, NO API KEY?                       │
# │ Set the one line below. TCGdex (https://tcgdex.dev) is a free, keyless    │
# │ API: real Pokémon catalog, images, and TCGplayer (USD) + Cardmarket (EUR) │
# │ prices. Catalog + raw pricing go live; no secrets, no Supabase needed.    │
# │ Graded/PSA prices + population stay clearly-labeled sample data.          │
# └─────────────────────────────────────────────────────────────────────────┘
PROVIDER_PRESET=demo   # demo (default) | tcgdex (free live) | pokemontcg

# Optional legacy path. NOTE: pokemontcg.io is now part of Scrydex and its
# commercial API is paid (~$29/mo); prefer PROVIDER_PRESET=tcgdex above.
POKEMON_TCG_API_KEY=

# --- Supabase (required only when DATA_MODE=live) ---
# On Vercel you MUST use your cloud project URL (https://YOUR_REF.supabase.co).
# A localhost / 127.0.0.1 URL from `supabase start` is unreachable from Vercel
# and will be ignored (app falls back to demo). Also set the anon + service keys
# from the same Supabase project, and run packages/database migrations once.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# --- Stripe (optional; mock billing when unset) ---
# Full setup guide: docs/STRIPE_BILLING.md
# Secret API key (sk_test_... in test mode). Server-only — never NEXT_PUBLIC.
STRIPE_SECRET_KEY=
# Signing secret for the webhook endpoint /api/webhooks/stripe (whsec_...).
STRIPE_WEBHOOK_SECRET=
# Price IDs from your Stripe dashboard — one per paid plan/interval. Checkout
# only ever uses these four (server-side allowlist):
#   Collector: $7.99/mo, $79/yr   ·   Pro: $19.99/mo, $199/yr
STRIPE_COLLECTOR_MONTHLY_PRICE_ID=
STRIPE_COLLECTOR_ANNUAL_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
# Optional: pin a specific Billing Portal configuration (bpc_...).
STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID=
# DEV ONLY: force a plan without Stripe (free|collector|pro). Ignored in
# production builds. Leave empty.
DEV_BILLING_PLAN_OVERRIDE=

# --- Upstash Redis (cache / locks / rate limiting; optional) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Trigger.dev (background jobs; optional) ---
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# --- Resend (transactional email; optional) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Sentry (monitoring; optional) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- PostHog (analytics; optional) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Vision service (grade-potential; optional local OpenCV microservice) ---
VISION_SERVICE_URL=
VISION_SERVICE_API_KEY=

# --- OpenAI (optional — LLM vision for Grade Potential + quick-scan ID) ---
# Create a key at https://platform.openai.com/api-keys
# Vercel: Project Settings → Environment Variables → add OPENAI_API_KEY.
# Keep this server-only name exactly as written (never prefix it with NEXT_PUBLIC_).
# When set, uploaded grade photos are analyzed by a vision model (default gpt-4o),
# and the quick-scan camera flow reads the card name/number with a vision model
# (default gpt-4o-mini) when on-device OCR can't — this is what makes scanning
# holo/foil cards reliable.
OPENAI_API_KEY=
OPENAI_GRADE_MODEL=gpt-4o
OPENAI_SCAN_MODEL=gpt-4o

# --- Anthropic (optional — Claude vision for scanning + grading) ---
# When set, Claude is the PREFERRED vision provider (OpenAI becomes fallback).
# Create a key at https://platform.claude.com → API keys, and make sure the
# account has billing/credits. Keep this server-only (never NEXT_PUBLIC_).
ANTHROPIC_API_KEY=
ANTHROPIC_SCAN_MODEL=claude-opus-4-8
ANTHROPIC_GRADE_MODEL=claude-opus-4-8

# --- Provider selectors ---
# Leave empty to follow PROVIDER_PRESET (recommended). Setting a value here —
# including "demo" — overrides the preset for that capability. With a live
# catalog, recognition defaults to catalog-ocr (the real scanner).
CATALOG_PROVIDER=
RECOGNITION_PROVIDER=
RAW_PRICING_PROVIDER=
# Graded pricing goes live automatically: PRICECHARTING_API_KEY (paid, real
# sold prices) wins, else EBAY_CLIENT_ID+SECRET (free, ask-based estimates).
# Leave empty to follow that; set "demo" to force demo data.
GRADED_PRICING_PROVIDER=
POPULATION_PROVIDER=demo
CERTIFICATION_PROVIDER=demo
ACTIVE_LISTINGS_PROVIDER=demo

# --- Provider credentials (only when the matching provider is selected) ---
SCRYDEX_API_KEY=
JUSTTCG_API_KEY=
POKEMON_TCG_API_KEY=
# PriceCharting: LIVE graded card prices (PSA 7-10, BGS/CGC/SGC 10) from real
# sold listings. Requires a paid PriceCharting subscription — the 40-char API
# token is on pricecharting.com → Subscription → "API/Download".
PRICECHARTING_API_KEY=
PSA_API_KEY=
# eBay Browse API: FREE graded-price estimates for PSA/BGS/CGC/SGC at every
# grade, derived from live eBay asking prices (clearly labeled as asks, not
# sold prices). Create a free developer account at developer.ebay.com →
# "Application Keys" → Production keyset: App ID = client id, Cert ID = client
# secret. No payment or approval process needed for the Browse API.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
